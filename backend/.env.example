# Free transactional email option: Brevo API.
# Set MAIL_PROVIDER=brevo_api and fill this from Brevo API Keys.
BREVO_API_KEY=

# Brevo SMTP fallback.
# Set MAIL_PROVIDER=brevo and fill these from Brevo Transactional SMTP.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
BREVO_FROM="Officer Charles <no-reply@officercharles.us>"

EMAIL_VERIFICATION_EXPIRES_MINUTES=10
EMAIL_VERIFICATION_EXPOSE_CODE=false

